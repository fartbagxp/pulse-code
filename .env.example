# Copy to .env and fill in the values you need, then: echo ".env" >> .gitignore (already ignored)

# Which LLM provider to use for build/query/refine/compare/chat. Defaults to "anthropic".
# Options: anthropic | azure_openai
LLM_PROVIDER=anthropic

# ── Anthropic (default provider) ────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Azure OpenAI Foundry (LLM_PROVIDER=azure_openai) ────────────────────────
# All four are required when LLM_PROVIDER=azure_openai.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=<your-gpt-5.4-deployment-name>
AZURE_OPENAI_API_VERSION=<api-version-your-resource-supports>

# ── Optional: proxy for LLM connections ─────────────────────────────────────
# Set this if the LLM endpoint (Anthropic or Azure OpenAI) isn't directly
# reachable and needs to be bridged through a proxy — e.g. Azure OpenAI
# resources with public access disabled / private-endpoint-only.
# Supports http://, https://, socks5://, and socks5h:// (DNS resolved
# through the proxy).
LLM_HTTP_PROXY=socks5h://user:pass@host:port
